---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allProducts = await getCollection("products", ({ data }) => data.is_active && data.oem_featured);
const oemProducts = allProducts
  .sort((a, b) => a.data.apis_launch_order - b.data.apis_launch_order);
---

<BaseLayout
  title="OEM 마커 제조 상담 | APIS 아피스"
  description="APIS 아피스 OEM 마커 제조 상담. 20년 제조 경험, MOQ 50개부터, 잉크·외관·패키지 완전 커스터마이징. B2B 전문 마커 제조사."
>

  <!-- Hero -->
  <section style="background:linear-gradient(135deg,var(--apis-primary),var(--apis-ink));color:#fff;padding:80px 0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;">
        <div>
          <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(233,69,96,0.15);border:1px solid rgba(233,69,96,0.3);color:#f87fa0;padding:6px 14px;border-radius:20px;font-size:0.8rem;font-weight:700;margin-bottom:20px;">
            🏭 OEM 제조 파트너
          </div>
          <h1 style="font-size:2.5rem;font-weight:900;line-height:1.2;margin-bottom:16px;">귀사의 마커 브랜드를<br/>아피스가 만들어 드립니다</h1>
          <p style="color:rgba(255,255,255,0.7);line-height:1.8;margin-bottom:32px;">소량 샘플부터 대량 양산까지, 잉크 배합·외관 디자인·패키지 모두 커스터마이징 가능합니다.</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            {[
              { icon: "📦", title: "MOQ 50개부터", desc: "소량 OEM 가능" },
              { icon: "🎨", title: "완전 커스터마이징", desc: "잉크·외관·패키지 맞춤" },
              { icon: "⚡", title: "3~5일 샘플 제공", desc: "빠른 의사결정 지원" },
              { icon: "🌐", title: "수출 대응 가능", desc: "CE 인증, 해외 포장" },
            ].map((item) => (
              <div style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:20px;">
                <div style="font-size:1.8rem;margin-bottom:8px;">{item.icon}</div>
                <h4 style="font-size:0.9rem;font-weight:700;margin-bottom:4px;">{item.title}</h4>
                <p style="font-size:0.8rem;color:rgba(255,255,255,0.6);">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- OEM Inquiry Form -->
        <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:20px;padding:36px;">
          <h2 style="font-size:1.3rem;font-weight:800;margin-bottom:8px;">OEM 상담 신청</h2>
          <p style="font-size:0.875rem;color:rgba(255,255,255,0.6);margin-bottom:28px;">아래 내용을 작성하시면 1영업일 내 연락드립니다.</p>
          <form method="POST" action="/api/oem-inquiry" style="display:grid;gap:14px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div>
                <label style="display:block;font-size:0.8rem;font-weight:600;color:rgba(255,255,255,0.7);margin-bottom:6px;">회사명 *</label>
                <input name="company" type="text" placeholder="주식회사 OOO" required
                  style="width:100%;padding:10px 14px;border-radius:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:#fff;font-size:0.875rem;" />
              </div>
              <div>
                <label style="display:block;font-size:0.8rem;font-weight:600;color:rgba(255,255,255,0.7);margin-bottom:6px;">담당자명 *</label>
                <input name="name" type="text" placeholder="홍길동" required
                  style="width:100%;padding:10px 14px;border-radius:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:#fff;font-size:0.875rem;" />
              </div>
            </div>
            <div>
              <label style="display:block;font-size:0.8rem;font-weight:600;color:rgba(255,255,255,0.7);margin-bottom:6px;">이메일 *</label>
              <input name="email" type="email" placeholder="contact@company.com" required
                style="width:100%;padding:10px 14px;border-radius:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:#fff;font-size:0.875rem;" />
            </div>
            <div>
              <label style="display:block;font-size:0.8rem;font-weight:600;color:rgba(255,255,255,0.7);margin-bottom:6px;">관심 제품군</label>
              <select name="product_group"
                style="width:100%;padding:10px 14px;border-radius:8px;background:rgba(26,26,46,0.9);border:1px solid rgba(255,255,255,0.2);color:#fff;font-size:0.875rem;">
                <option value="">선택해 주세요</option>
                <option>유성마커 / 네임펜</option>
                <option>보드마커 / 형광펜</option>
                <option>패브릭 / 아크릴 마커</option>
                <option>기능성 마커 (철재·콘크리트)</option>
                <option>수성 사인펜</option>
                <option>마커 세트</option>
                <option>기타</option>
              </select>
            </div>
            <div>
              <label style="display:block;font-size:0.8rem;font-weight:600;color:rgba(255,255,255,0.7);margin-bottom:6px;">예상 발주량 (월)</label>
              <select name="quantity"
                style="width:100%;padding:10px 14px;border-radius:8px;background:rgba(26,26,46,0.9);border:1px solid rgba(255,255,255,0.2);color:#fff;font-size:0.875rem;">
                <option value="">선택해 주세요</option>
                <option>50~500개 (소량)</option>
                <option>500~5,000개 (중량)</option>
                <option>5,000~50,000개 (대량)</option>
                <option>50,000개 이상 (초대량)</option>
              </select>
            </div>
            <div>
              <label style="display:block;font-size:0.8rem;font-weight:600;color:rgba(255,255,255,0.7);margin-bottom:6px;">상담 내용</label>
              <textarea name="message" rows="4"
                placeholder="커스터마이징 요구사항, 납기, 수출 여부 등을 자유롭게 작성해 주세요."
                style="width:100%;padding:10px 14px;border-radius:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:#fff;font-size:0.875rem;resize:vertical;font-family:inherit;"></textarea>
            </div>
            <button type="submit"
              style="width:100%;padding:14px;border-radius:10px;background:var(--apis-accent);color:#fff;border:none;font-size:1rem;font-weight:700;cursor:pointer;font-family:inherit;">
              ✦ 상담 신청하기
            </button>
          </form>

          <!-- Lead Grade Info -->
          <div style="display:flex;gap:8px;margin-top:20px;justify-content:center;flex-wrap:wrap;">
            {[
              { label: "A급: 즉시 상담", color: "#4ade80", bg: "rgba(34,197,94,0.15)", border: "rgba(34,197,94,0.3)" },
              { label: "B급: 우선 검토", color: "#60a5fa", bg: "rgba(59,130,246,0.15)", border: "rgba(59,130,246,0.3)" },
              { label: "C급: 일반 대기", color: "#f5a623", bg: "rgba(245,166,35,0.15)", border: "rgba(245,166,35,0.3)" },
            ].map((grade) => (
              <span style={`background:${grade.bg};border:1px solid ${grade.border};color:${grade.color};padding:4px 12px;border-radius:20px;font-size:0.72rem;font-weight:700;`}>
                {grade.label}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OEM Available Products -->
  {oemProducts.length > 0 && (
    <section class="section bg-light">
      <div class="container">
        <div class="text-center">
          <h2 class="section-title">OEM 제조 가능 제품</h2>
          <p class="section-sub">아래 제품들을 기반으로 브랜드 커스터마이징이 가능합니다</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
          {oemProducts.map((product) => (
            <a href={`/products/${product.slug}`}
              style="background:#fff;border:1px solid var(--apis-border);border-radius:16px;padding:28px;display:block;transition:all 0.3s;">
              <h3 style="font-size:1rem;font-weight:800;margin-bottom:8px;">{product.data.title_short || product.data.title}</h3>
              <p style="font-size:0.85rem;color:var(--apis-gray);margin-bottom:16px;">{product.data.description.slice(0, 60)}...</p>
              {product.data.specs?.moq_oem && (
                <span style="background:rgba(233,69,96,0.1);color:var(--apis-accent);padding:4px 12px;border-radius:8px;font-size:0.75rem;font-weight:700;">
                  MOQ {product.data.specs.moq_oem.toLocaleString()}개
                </span>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
