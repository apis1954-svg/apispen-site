---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const products = await getCollection("products", ({ data }) => data.is_active);
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;
const { Content } = await product.render();

const categoryIcons: Record<string, string> = {
  "permanent-marker": "🖊️",
  "name-pen": "✒️",
  "board-marker": "📊",
  "highlighter": "🌟",
  "fabric-marker": "👗",
  "washable-marker": "🧺",
  "functional-marker": "🔧",
  "waterbased-sign-pen": "🖋️",
  "acrylic-marker": "🎨",
  "marker-set": "📦",
  "oem-item": "🏭",
};
---

<BaseLayout
  title={data.seo_title || `${data.title} | APIS 아피스`}
  description={data.seo_description || data.description}
  ogImage={data.og_image}
>

  <!-- Breadcrumb -->
  <div style="background:var(--apis-light);padding:16px 0;border-bottom:1px solid var(--apis-border);">
    <div class="container">
      <nav style="font-size:0.85rem;color:var(--apis-gray);">
        <a href="/">홈</a> &nbsp;/&nbsp;
        <a href="/categories">카테고리</a> &nbsp;/&nbsp;
        <a href={`/categories/${data.primary_sales_group}`}>{data.primary_sales_group.replace(/-/g, " ")}</a> &nbsp;/&nbsp;
        <span>{data.title_short || data.title}</span>
      </nav>
    </div>
  </div>

  <!-- Product Detail -->
  <section class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;">

        <!-- Product Image -->
        <div>
          <div style="height:400px;background:var(--apis-light);border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:8rem;border:1px solid var(--apis-border);">
            {categoryIcons[data.category] || "📦"}
          </div>
          {data.specs?.colors_available && data.specs.colors_available.length > 0 && (
            <div style="margin-top:20px;">
              <p style="font-size:0.875rem;font-weight:700;margin-bottom:12px;">색상 구성</p>
              <div style="display:flex;gap:8px;flex-wrap:wrap;">
                {data.specs.colors_available.map((color) => (
                  <span style="background:var(--apis-light);border:1px solid var(--apis-border);padding:6px 14px;border-radius:8px;font-size:0.8rem;">{color}</span>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Product Info -->
        <div>
          <div style="font-size:0.8rem;color:var(--apis-accent);font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;">
            {data.category.replace(/-/g, " ")}
          </div>
          <h1 style="font-size:1.8rem;font-weight:900;line-height:1.3;margin-bottom:12px;">{data.title}</h1>
          {data.subtitle && (
            <p style="font-size:1rem;color:var(--apis-gray);margin-bottom:20px;font-style:italic;">{data.subtitle}</p>
          )}
          <p style="font-size:0.95rem;color:var(--apis-gray);line-height:1.8;margin-bottom:28px;">{data.description}</p>

          <!-- Specs Table -->
          {data.specs && (
            <div style="background:var(--apis-light);border-radius:12px;padding:24px;margin-bottom:28px;">
              <h3 style="font-size:1rem;font-weight:800;margin-bottom:16px;">제품 사양</h3>
              <table style="width:100%;font-size:0.875rem;">
                <tbody>
                  {data.specs.ink_type && (
                    <tr style="border-bottom:1px solid var(--apis-border);">
                      <td style="padding:8px 0;color:var(--apis-gray);width:40%;">잉크 타입</td>
                      <td style="padding:8px 0;font-weight:600;">{data.specs.ink_type}</td>
                    </tr>
                  )}
                  {data.specs.tip_type && (
                    <tr style="border-bottom:1px solid var(--apis-border);">
                      <td style="padding:8px 0;color:var(--apis-gray);">팁 타입</td>
                      <td style="padding:8px 0;font-weight:600;">{data.specs.tip_type}</td>
                    </tr>
                  )}
                  {data.specs.tip_size_mm && (
                    <tr style="border-bottom:1px solid var(--apis-border);">
                      <td style="padding:8px 0;color:var(--apis-gray);">팁 사이즈</td>
                      <td style="padding:8px 0;font-weight:600;">{data.specs.tip_size_mm}mm</td>
                    </tr>
                  )}
                  {data.specs.quantity_per_pack && (
                    <tr style="border-bottom:1px solid var(--apis-border);">
                      <td style="padding:8px 0;color:var(--apis-gray);">기본 수량</td>
                      <td style="padding:8px 0;font-weight:600;">{data.specs.quantity_per_pack}개입</td>
                    </tr>
                  )}
                  {data.specs.moq_oem && (
                    <tr style="border-bottom:1px solid var(--apis-border);">
                      <td style="padding:8px 0;color:var(--apis-gray);">OEM MOQ</td>
                      <td style="padding:8px 0;font-weight:600;">{data.specs.moq_oem.toLocaleString()}개부터</td>
                    </tr>
                  )}
                  {data.specs.made_in && (
                    <tr>
                      <td style="padding:8px 0;color:var(--apis-gray);">제조국</td>
                      <td style="padding:8px 0;font-weight:600;">{data.specs.made_in}</td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
          )}

          <!-- CTA Buttons -->
          <div style="display:flex;gap:12px;flex-wrap:wrap;">
            {data.coupang_url ? (
              <a
                href={data.coupang_url}
                target="_blank"
                rel="noopener noreferrer nofollow"
                style="background:var(--apis-accent);color:#fff;padding:14px 28px;border-radius:10px;font-weight:700;font-size:0.95rem;display:inline-flex;align-items:center;gap:8px;"
              >
                🛒 쿠팡에서 구매하기
              </a>
            ) : (
              <span style="background:var(--apis-border);color:var(--apis-gray);padding:14px 28px;border-radius:10px;font-weight:700;font-size:0.95rem;">
                쿠팡 판매 준비 중
              </span>
            )}
            {data.oem_featured && (
              <a
                href="/oem"
                style="background:var(--apis-primary);color:#fff;padding:14px 28px;border-radius:10px;font-weight:700;font-size:0.95rem;"
              >
                🏭 OEM 문의
              </a>
            )}
          </div>

          <!-- Certifications -->
          {data.specs?.certifications && data.specs.certifications.length > 0 && (
            <div style="margin-top:20px;display:flex;gap:8px;flex-wrap:wrap;">
              {data.specs.certifications.map((cert) => (
                <span style="background:rgba(34,197,94,0.1);color:#16a34a;border:1px solid rgba(34,197,94,0.3);padding:4px 12px;border-radius:20px;font-size:0.75rem;font-weight:700;">
                  ✓ {cert}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- MDX Content -->
      <div style="max-width:800px;margin:60px auto 0;font-size:0.95rem;line-height:1.9;color:var(--apis-primary);">
        <Content />
      </div>
    </div>
  </section>

</BaseLayout>
